{
  "name": "proyecto-travelhub",
  "version": "0.0.0",
  "license": "UNLICENSED",
  "private": true,
  "packageManager": "pnpm@10.0.0",
  "engines": {
    "node": ">=24 <25"
  },
  "scripts": {
    "start": "nx run-many -t serve",
    "build": "nx run-many -t build",
    "build:frontend": "nx build frontend",
    "build:services": "nx run-many -t build --projects=api-gateway,auth-service,search-service,inventory-service,booking-service,payment-service,notification-service,partners-service",
    "serve:api-gateway": "nx serve api-gateway",
    "serve:auth": "nx serve auth-service",
    "serve:search": "nx serve search-service",
    "serve:inventory": "nx serve inventory-service",
    "serve:booking": "nx serve booking-service",
    "serve:payment": "nx serve payment-service",
    "serve:notification": "nx serve notification-service",
    "serve:partners": "nx serve partners-service",
    "serve:frontend": "nx serve frontend",
    "start:mobile": "nx start mobile",
    "test": "NX_DAEMON=false NX_TUI=false nx run-many -t test --outputStyle=static",
    "lint": "NX_DAEMON=false NX_TUI=false nx run-many -t lint --outputStyle=static",
    "lint:fix": "NX_DAEMON=false NX_TUI=false nx run-many -t lint --fix --outputStyle=static",
    "graph": "nx graph",
    "affected:build": "NX_DAEMON=false NX_TUI=false nx affected -t build --outputStyle=static",
    "affected:test": "NX_DAEMON=false NX_TUI=false nx affected -t test --outputStyle=static",
    "affected:lint": "NX_DAEMON=false NX_TUI=false nx affected -t lint --outputStyle=static",
    "typecheck": "tsc --noEmit -p services/api-gateway/tsconfig.json && tsc --noEmit -p services/auth-service/tsconfig.json && tsc --noEmit -p services/booking-service/tsconfig.json && tsc --noEmit -p services/inventory-service/tsconfig.json && tsc --noEmit -p services/notification-service/tsconfig.json && tsc --noEmit -p services/partners-service/tsconfig.json && tsc --noEmit -p services/payment-service/tsconfig.json && tsc --noEmit -p services/search-service/tsconfig.json && tsc --noEmit -p frontend/tsconfig.app.json && tsc --noEmit -p frontend/tsconfig.spec.json && tsc --noEmit -p mobile/tsconfig.json && tsc --noEmit -p mobile/tsconfig.spec.json",
    "docker:dev": "docker build -t travelhub-base -f docker/Dockerfile.base . && docker compose up --build",
    "docker:down": "docker compose down -v",
    "infra:install": "cd pulumi && pnpm install",
    "infra:preview": "cd pulumi && pulumi preview",
    "infra:up": "cd pulumi && pulumi up",
    "infra:down": "cd pulumi && pulumi destroy",
    "deploy:frontend": "pnpm run build:frontend && aws s3 sync dist/frontend/ s3://$(cd pulumi && pulumi stack output frontendBucket)/ --delete && aws cloudfront create-invalidation --distribution-id $(cd pulumi && pulumi stack output cdnId 2>/dev/null || echo '') --paths '/*'",
    "prepare": "husky"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@nestjs/core",
      "@parcel/watcher",
      "@pulumi/docker",
      "@pulumi/docker-build",
      "detox",
      "dtrace-provider",
      "esbuild",
      "less",
      "nx",
      "protobufjs",
      "unrs-resolver"
    ]
  },
  "dependencies": {
    "@expo/vector-icons": "^15.0.3",
    "@nestjs/common": "^11.0.1",
    "@nestjs/core": "^11.0.1",
    "@nestjs/platform-express": "^11.0.1",
    "@react-navigation/bottom-tabs": "^7.4.0",
    "@react-navigation/elements": "^2.6.3",
    "@react-navigation/native": "^7.1.8",
    "expo": "~54.0.33",
    "expo-constants": "~18.0.13",
    "expo-font": "~14.0.11",
    "expo-haptics": "~15.0.8",
    "expo-image": "~3.0.11",
    "expo-linking": "~8.0.11",
    "expo-router": "~6.0.23",
    "expo-splash-screen": "~31.0.13",
    "expo-status-bar": "~3.0.9",
    "expo-symbols": "~1.0.8",
    "expo-system-ui": "~6.0.9",
    "expo-web-browser": "~15.0.10",
    "i18next": "^25.8.18",
    "kysely": "^0.28.12",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-i18next": "^16.5.8",
    "react-native": "0.81.5",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-web": "~0.21.0",
    "react-native-worklets": "0.5.1",
    "reflect-metadata": "^0.2.2",
    "tslib": "^2.8.1",
    "rxjs": "^7.8.1"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.2.0",
    "@eslint/js": "^9.39.1",
    "@nestjs/cli": "^11.0.0",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.0.1",
    "@nx/expo": "^22.5.1",
    "@nx/jest": "^22.5.1",
    "@nx/js": "^22.5.1",
    "@nx/nest": "^22.5.1",
    "@nx/react": "^22.5.1",
    "@nx/vite": "^22.5.1",
    "@nx/webpack": "^22.5.1",
    "@tailwindcss/vite": "^4.2.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/express": "^5.0.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^24.10.1",
    "@types/pg": "^8.18.0",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@types/supertest": "^6.0.2",
    "@vitejs/plugin-react": "^5.1.1",
    "eslint": "^9.39.1",
    "eslint-config-expo": "~10.0.0",
    "eslint-config-prettier": "^10.0.1",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-prettier": "^5.2.2",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "husky": "^9.1.7",
    "jest": "^30.0.0",
    "jest-environment-jsdom": "^30.3.0",
    "lint-staged": "^16.3.3",
    "nx": "^22.5.1",
    "pg": "^8.20.0",
    "prettier": "^3.4.2",
    "source-map-support": "^0.5.21",
    "supertest": "^7.0.0",
    "tailwindcss": "^4.2.1",
    "ts-jest": "^29.2.5",
    "ts-loader": "^9.5.2",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.48.0",
    "vite": "^7.3.1"
  }
}
