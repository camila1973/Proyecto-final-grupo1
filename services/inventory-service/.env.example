# PostgreSQL connection string for the inventory-service database
DATABASE_URL=postgres://postgres:postgres@localhost:5434/travelhub

# ── Message broker ────────────────────────────────────────────────────────────
# Local development (docker compose): rabbitmq
# GCP production:                     pubsub
MESSAGE_BROKER_TYPE=rabbitmq

# RabbitMQ — used when MESSAGE_BROKER_TYPE=rabbitmq
RABBITMQ_URL=amqp://guest:guest@localhost:5672

# Google Pub/Sub — used when MESSAGE_BROKER_TYPE=pubsub
# PUBSUB_PROJECT_ID=my-gcp-project

# HTTP port (default: 3003)
PORT=3003
