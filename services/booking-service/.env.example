PORT=3004
DATABASE_URL=postgres://postgres:postgres@localhost:5436/travelhub?sslmode=disable
MESSAGE_BROKER_URL=amqp://guest:guest@localhost:5672
MESSAGE_BROKER_TYPE=rabbitmq
REDIS_URL=redis://localhost:6379

# Downstream services
INVENTORY_SERVICE_URL=http://localhost:3003
NOTIFICATION_SERVICE_URL=http://localhost:3006
PARTNERS_SERVICE_URL=http://localhost:3007

# Shared secret for /internal/reservations/* endpoints. Cloud Scheduler sends
# this in the X-Internal-Token header in production; pnpm run cron:* helpers
# use the same default locally. In production this value is sourced from
# Secret Manager (travelhub-internal-cron-secret) via Pulumi.
INTERNAL_CRON_SECRET=local-cron-dev-secret
