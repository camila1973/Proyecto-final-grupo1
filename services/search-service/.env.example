# PostgreSQL connection string for the search-service database
DATABASE_URL=postgres://postgres:postgres@localhost:5432/search_service

# Redis connection string
REDIS_URL=redis://localhost:6379

# Message broker connection URL
MESSAGE_BROKER_URL=amqp://guest:guest@localhost:5672

# Message broker type: rabbitmq | sqs
MESSAGE_BROKER_TYPE=rabbitmq

# HTTP port (default: 3002)
PORT=3002

# Inventory service base URL (used for live availability checks)
INVENTORY_SERVICE_URL=http://inventory-service:3003
