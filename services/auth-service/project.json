{
  "name": "auth-service",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "services/auth-service/src",
  "projectType": "application",
  "tags": ["scope:backend"],
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "outputs": ["{workspaceRoot}/dist/auth-service"],
      "options": { "command": "nest build", "cwd": "services/auth-service" }
    },
    "serve": {
      "executor": "nx:run-commands",
      "options": { "command": "node ../../dist/auth-service/main.js", "cwd": "services/auth-service" }
    },
    "lint": {
      "executor": "@nx/eslint:lint",
      "outputs": ["{options.outputFile}"],
      "options": { "lintFilePatterns": ["services/auth-service/src/**/*.ts"] }
    },
    "test": {
      "executor": "@nx/jest:jest",
      "outputs": ["{workspaceRoot}/coverage/auth-service"],
      "options": { "jestConfig": "services/auth-service/jest.config.js", "passWithNoTests": true }
    }
  }
}
