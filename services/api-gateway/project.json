{
  "name": "api-gateway",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "services/api-gateway/src",
  "projectType": "application",
  "tags": ["scope:backend"],
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "outputs": ["{workspaceRoot}/dist/api-gateway"],
      "options": { "command": "nest build", "cwd": "services/api-gateway" }
    },
    "serve": {
      "executor": "nx:run-commands",
      "options": { "command": "node ../../dist/api-gateway/main.js", "cwd": "services/api-gateway" }
    },
    "lint": {
      "executor": "@nx/eslint:lint",
      "outputs": ["{options.outputFile}"],
      "options": { "lintFilePatterns": ["services/api-gateway/src/**/*.ts"] }
    },
    "test": {
      "executor": "@nx/jest:jest",
      "outputs": ["{workspaceRoot}/coverage/api-gateway"],
      "options": { "jestConfig": "services/api-gateway/jest.config.js", "passWithNoTests": true }
    }
  }
}
