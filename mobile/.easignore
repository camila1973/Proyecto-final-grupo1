# EAS Build uses this file (when present) instead of .gitignore to decide
# which files to bundle for the build. Mirror mobile/.gitignore *except* the
# Firebase config entries: those are gitignored as secrets, but the
# `firebase-config` composite action materializes them from base64 GH Secrets
# right before `eas build --local`, and EAS must include them so that
# `expo prebuild` can copy them into android/app/.

expo-env.d.ts

# Generated native directories (expo prebuild handles these during EAS build).
android/
ios/
