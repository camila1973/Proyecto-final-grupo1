{
  "name": "frontend-e2e",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "projectType": "application",
  "implicitDependencies": ["frontend"],
  "targets": {
    "e2e": {
      "executor": "nx:run-commands",
      "options": {
        "command": "pnpm exec playwright test --config e2e/frontend/playwright.config.ts"
      }
    },
    "e2e-headed": {
      "executor": "nx:run-commands",
      "options": {
        "command": "pnpm exec playwright test --config e2e/frontend/playwright.config.ts --headed"
      }
    },
    "e2e-ui": {
      "executor": "nx:run-commands",
      "options": {
        "command": "pnpm exec playwright test --config e2e/frontend/playwright.config.ts --ui"
      }
    },
    "e2e-debug": {
      "executor": "nx:run-commands",
      "options": {
        "command": "pnpm exec playwright test --config e2e/frontend/playwright.config.ts --debug"
      }
    }
  }
}
